{
  "$schema": "https://raw.githubusercontent.com/AArnott/Nerdbank.GitVersioning/master/src/NerdBank.GitVersioning/version.schema.json",
  "version": "10.1",
  "publicReleaseRefSpec": [
    "^refs/heads/main$",
